#!/usr/bin/expect -f
# Control commands with --no-agent (fast: no pi needed, only verifies signals)
set timeout 10
catch {unset env(PISH_PID)}
spawn node [file dirname [info script]]/../../dist/main.js --no-agent
expect -re {PISH_READY} {}
sleep 0.1
send "/compact\r"
expect -re {PISH_READY} {}
sleep 0.1
send "/model sonnet\r"
expect -re {PISH_READY} {}
sleep 0.1
send "/think high\r"
expect -re {PISH_READY} {}
sleep 0.1
send "exit\r"
expect eof
