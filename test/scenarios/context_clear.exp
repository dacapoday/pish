#!/usr/bin/expect -f
set timeout 10
catch {unset env(PISH_PID)}
spawn node [file dirname [info script]]/../../dist/main.js
expect -re {PISH_READY} {}
sleep 0.1
send "echo before_clear\r"
expect -re {PISH_READY} {}
sleep 0.1
# Ctrl+L = clear context
send "\x0c"
expect -re {PISH_READY} {}
sleep 0.1
send "exit\r"
expect eof
